# Bloco temporario ativo agora.
# Quando o dominio domainsecurity.com.br estiver aprovado e apontado,
# substitua este bloco pelo bloco final comentado abaixo.
:80 {
    reverse_proxy app:8000
    encode gzip zstd
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
    log {
        output stdout
        format json
    }
}

