DSC_APP_NAME=Domain Security Checker
DSC_DATABASE_URL=sqlite:///./domain_security.db
DSC_DNS_TIMEOUT_SECONDS=2.5
DSC_WEBSITE_TLS_TIMEOUT_SECONDS=3.0
DSC_EMAIL_TLS_TIMEOUT_SECONDS=2.5
DSC_RDAP_TIMEOUT_SECONDS=2.0
DSC_MX_PROBE_LIMIT=2
DSC_ANALYSIS_CACHE_TTL_SECONDS=300
DSC_RDAP_BASE_URL=https://rdap.org/domain/
DSC_SESSION_SECRET=change-me-in-production
DSC_SESSION_MAX_AGE_SECONDS=604800
DSC_MONITORING_SCHEDULER_ENABLED=true
DSC_MONITORING_POLL_SECONDS=60
DSC_MONITORING_SCORE_DROP_THRESHOLD=15

DSC_GEOIP_ENABLED=true
DSC_GEOIP_PROVIDER=maxmind
DSC_GEOIP_CITY_DB_PATH=
DSC_GEOIP_ASN_DB_PATH=
DSC_GEOIP_ISP_DB_PATH=
DSC_GEOIP_ANONYMOUS_DB_PATH=
DSC_GEOIP_ACCOUNT_ID=
DSC_GEOIP_LICENSE_KEY=
DSC_GEOIP_HOST=
DSC_GEOIP_TIMEOUT_SECONDS=2.5

DSC_EMAIL_DELIVERY_ENABLED=false
DSC_SMTP_HOST=
DSC_SMTP_PORT=587
DSC_SMTP_USERNAME=
DSC_SMTP_PASSWORD=
DSC_SMTP_USE_TLS=true
DSC_SMTP_USE_SSL=false
DSC_SMTP_TIMEOUT_SECONDS=5.0
DSC_SMTP_FROM_EMAIL=
DSC_SMTP_FROM_NAME=Domain Security Checker

DSC_ASSET_DISCOVERY_ENABLED=false
DSC_ASSET_DISCOVERY_PROVIDER=amass
DSC_AMASS_BINARY_PATH=amass
DSC_AMASS_TIMEOUT_SECONDS=300
DSC_AMASS_PASSIVE_MODE=true
